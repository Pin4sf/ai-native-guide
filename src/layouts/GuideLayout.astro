---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getReadingTime, formatReadingTime } from '../utils/reading-time';

interface Props {
  title: string;
  description: string;
  author: string;
  publishedDate: Date;
  updatedDate?: Date;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  slug: string;
  series?: { name: string; order: number; total: number };
}

const {
  title, description, author, publishedDate, updatedDate,
  difficulty, tags, headings, body, slug, series
} = Astro.props;

const readingTime = getReadingTime(body);
const formattedDate = publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const badgeClass = {
  beginner: 'badge-beginner',
  intermediate: 'badge-intermediate',
  advanced: 'badge-advanced',
}[difficulty];

const editUrl = `https://github.com/Pin4sf/ai-native-guide/edit/main/src/content/guides/${slug}.mdx`;
---

<BaseLayout title={title} description={description} ogType="article">
  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true"></div>

  <article class="full-layout px-6 pt-12 pb-16">
    <!-- Series nav (if applicable) -->
    {series && (
      <div class="max-w-prose mx-auto xl:mx-0 mb-4">
        <span class="font-heading text-xs font-semibold text-accent dark:text-accent-dark uppercase tracking-wider">
          {series.name} · Part {series.order} of {series.total}
        </span>
      </div>
    )}

    <!-- Article header -->
    <header class="max-w-prose mx-auto xl:mx-0 mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class:list={["badge", badgeClass]}>{difficulty}</span>
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="tag-pill hover:no-underline">{tag}</a>
        ))}
      </div>

      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text dark:text-text-dark leading-tight mb-4">
        {title}
      </h1>

      <p class="text-muted dark:text-muted-dark text-lg leading-relaxed mb-4">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-3 text-sm text-muted dark:text-muted-dark font-heading">
        <span>By {author}</span>
        <span>·</span>
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{formatReadingTime(readingTime)}</span>
      </div>
    </header>

    <!-- Content + ToC layout -->
    <div class="flex gap-12 justify-center xl:justify-start">
      <!-- Main content -->
      <div class="prose prose-lg dark:prose-invert prose-headings:scroll-mt-24 min-w-0 flex-1 max-w-prose" style="counter-reset: sidenote-counter;">
        <slot />
      </div>

      <!-- Table of Contents (desktop only, right side) -->
      <TableOfContents headings={headings} />
    </div>

    <!-- Article footer -->
    <footer class="max-w-prose mx-auto xl:mx-0 mt-16 pt-8 border-t border-border dark:border-border-dark">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="text-sm text-muted dark:text-muted-dark">
          {updatedDate && (
            <span>Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          )}
        </div>
        <a
          href={editUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-sm font-heading font-medium text-muted dark:text-muted-dark hover:text-accent dark:hover:text-accent-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
          Suggest Edit
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
