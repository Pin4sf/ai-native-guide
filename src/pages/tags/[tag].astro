---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const allGuides = await getCollection('guides', ({ data }) => !data.draft);
  const allTags = [...new Set(allGuides.flatMap(g => g.data.tags))];

  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      guides: allGuides
        .filter(g => g.data.tags.includes(tag))
        .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()),
    },
  }));
}

const { tag, guides } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Guides tagged with "${tag}".`}>
  <section class="pt-12 pb-20 px-6">
    <div class="full-layout max-w-4xl">
      <div class="mb-8">
        <a href="/tags" class="font-heading text-sm text-muted dark:text-muted-dark hover:text-accent dark:hover:text-accent-dark transition-colors mb-2 inline-block">← All Tags</a>
        <h1 class="font-heading text-3xl font-bold text-text dark:text-text-dark">#{tag}</h1>
        <p class="text-muted dark:text-muted-dark mt-1">{guides.length} guide{guides.length !== 1 ? 's' : ''}</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {guides.map((guide) => (
          <div class="reveal">
            <GuideCard
              title={guide.data.title}
              description={guide.data.description}
              slug={guide.id}
              difficulty={guide.data.difficulty}
              tags={guide.data.tags}
              readingTime={getReadingTime(guide.body || '')}
              author={guide.data.author}
              publishedDate={guide.data.publishedDate}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
