---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);

// Build tag → count map
const tagCounts = new Map<string, number>();
allGuides.forEach(guide => {
  guide.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="Browse guides by topic.">
  <section class="pt-12 pb-20 px-6">
    <div class="full-layout max-w-3xl">
      <h1 class="font-heading text-3xl font-bold text-text dark:text-text-dark mb-3">Tags</h1>
      <p class="text-muted dark:text-muted-dark mb-8">Browse guides by topic.</p>

      <div class="flex flex-wrap gap-3">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center gap-2 px-4 py-2 border border-border dark:border-border-dark rounded-lg hover:border-accent dark:hover:border-accent-dark transition-colors group"
          >
            <span class="font-heading text-sm font-medium text-text dark:text-text-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{tag}</span>
            <span class="font-heading text-xs text-muted dark:text-muted-dark">{count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
