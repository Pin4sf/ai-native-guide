---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

<!-- Desktop: sticky sidebar -->
<aside class="hidden xl:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 w-56 shrink-0">
  <p class="font-heading text-xs font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mb-3">
    On this page
  </p>
  <nav>
    <ul class="space-y-1.5 text-sm border-l border-border dark:border-border-dark">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              "toc-link block py-0.5 transition-colors text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark",
              heading.depth === 2 ? "pl-3 font-medium" : "pl-6 text-xs",
            ]}
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<!-- Mobile: collapsible -->
<details class="xl:hidden mb-8 border border-border dark:border-border-dark rounded-lg">
  <summary class="px-4 py-3 cursor-pointer font-heading text-sm font-semibold text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark select-none">
    ▶ On this page
  </summary>
  <nav class="px-4 pb-3">
    <ul class="space-y-1 text-sm">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              "block py-0.5 text-muted dark:text-muted-dark hover:text-accent dark:hover:text-accent-dark transition-colors",
              heading.depth === 2 ? "font-medium" : "pl-3 text-xs",
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</details>

<script>
  function initToC() {
    const tocLinks = document.querySelectorAll('.toc-link');
    if (!tocLinks.length) return;

    const headingSlugs = Array.from(tocLinks).map(link => (link as HTMLElement).dataset.heading!);
    const headingElements = headingSlugs.map(slug => document.getElementById(slug)).filter(Boolean) as HTMLElement[];

    if (!headingElements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const slug = entry.target.id;
            tocLinks.forEach(link => {
              const el = link as HTMLElement;
              if (el.dataset.heading === slug) {
                el.classList.add('!text-accent', 'dark:!text-accent-dark', '!border-l-2', '!border-accent');
                el.classList.remove('text-muted', 'dark:text-muted-dark');
              } else {
                el.classList.remove('!text-accent', 'dark:!text-accent-dark', '!border-l-2', '!border-accent');
                el.classList.add('text-muted', 'dark:text-muted-dark');
              }
            });
          }
        }
      },
      { rootMargin: '0px 0px -80% 0px', threshold: 0 }
    );

    headingElements.forEach(el => observer.observe(el));
  }

  initToC();
  document.addEventListener('astro:after-swap', initToC);
</script>
