---
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-cream/80 dark:bg-cream-dark/80 border-b border-border dark:border-border-dark">
  <div class="full-layout px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-heading font-bold text-lg text-text dark:text-text-dark hover:text-accent dark:hover:text-accent-dark transition-colors">
      <span class="text-xl">✦</span>
      <span>AI Native Guide</span>
    </a>

    <!-- Navigation -->
    <div class="flex items-center gap-6">
      <a
        href="/guides"
        class:list={[
          "font-heading text-sm font-medium transition-colors",
          currentPath.startsWith('/guides')
            ? "text-accent dark:text-accent-dark"
            : "text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark"
        ]}
      >
        Guides
      </a>
      <a
        href="/tags"
        class:list={[
          "font-heading text-sm font-medium transition-colors",
          currentPath.startsWith('/tags')
            ? "text-accent dark:text-accent-dark"
            : "text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark"
        ]}
      >
        Tags
      </a>
      <a
        href="/about"
        class:list={[
          "font-heading text-sm font-medium transition-colors",
          currentPath === '/about'
            ? "text-accent dark:text-accent-dark"
            : "text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark"
        ]}
      >
        About
      </a>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-colors text-muted dark:text-muted-dark"
        aria-label="Toggle dark mode"
      >
        <svg id="sun-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" /><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg id="moon-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<script>
  function initTheme() {
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');

    function getTheme(): string {
      const stored = localStorage.getItem('theme');
      if (stored) return stored;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(theme: string) {
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        sunIcon?.classList.remove('hidden');
        moonIcon?.classList.add('hidden');
      } else {
        document.documentElement.classList.remove('dark');
        sunIcon?.classList.add('hidden');
        moonIcon?.classList.remove('hidden');
      }
    }

    applyTheme(getTheme());

    toggle?.addEventListener('click', () => {
      const current = getTheme();
      const next = current === 'dark' ? 'light' : 'dark';
      localStorage.setItem('theme', next);
      applyTheme(next);
    });
  }

  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>
